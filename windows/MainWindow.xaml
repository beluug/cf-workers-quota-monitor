<Window x:Class="CFQuotaMonitor.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CF Quota Monitor" Width="1180" Height="780" MinWidth="900" MinHeight="620"
        WindowStartupLocation="CenterScreen" Closing="Window_Closing" Activated="Window_Activated" Deactivated="Window_Deactivated">
  <Window.Resources>
    <Style x:Key="NavButton" TargetType="Button">
      <Setter Property="Foreground" Value="#B9C0D4" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="Padding" Value="18,12" />
      <Setter Property="Margin" Value="12,3" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="9" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bg" Property="Background" Value="#202A48" /></Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="Card" TargetType="Border">
      <Setter Property="Background" Value="White" />
      <Setter Property="BorderBrush" Value="#E4E7EC" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="Padding" Value="20" />
    </Style>
    <Style x:Key="SectionLabel" TargetType="TextBlock">
      <Setter Property="Foreground" Value="#667085" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Margin" Value="0,0,0,10" />
    </Style>
    <Style x:Key="SettingsCheck" TargetType="CheckBox">
      <Setter Property="FontSize" Value="15" />
      <Setter Property="Foreground" Value="#182033" />
      <Setter Property="Margin" Value="0,6" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
  </Window.Resources>

  <Grid x:Name="RootGrid" Background="#F4F6FB">
    <Grid.ColumnDefinitions><ColumnDefinition Width="224" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>

    <Border Grid.Column="0" Background="#11182C">
      <Grid>
        <Grid.RowDefinitions><RowDefinition Height="104" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Margin="20,25,15,20">
          <Border Width="48" Height="48" CornerRadius="13" Background="#5B5FEF">
            <TextBlock Text="CF" Foreground="White" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <StackPanel Margin="11,3,0,0" VerticalAlignment="Center">
            <TextBlock x:Name="SidebarTitle" Foreground="White" FontWeight="Bold" FontSize="13" />
            <TextBlock Text="WINDOWS" Foreground="#75809D" FontSize="10" FontWeight="Bold" Margin="0,3,0,0" />
          </StackPanel>
        </StackPanel>
        <StackPanel Grid.Row="1">
          <Button x:Name="DashboardNav" Style="{StaticResource NavButton}" Click="DashboardNav_Click" />
          <Button x:Name="AccountsNav" Style="{StaticResource NavButton}" Click="AccountsNav_Click" />
          <Button x:Name="TransferNav" Style="{StaticResource NavButton}" Click="TransferNav_Click" />
          <Button x:Name="SettingsNav" Style="{StaticResource NavButton}" Click="SettingsNav_Click" />
          <Button x:Name="HelpNav" Style="{StaticResource NavButton}" Click="HelpNav_Click" />
        </StackPanel>
        <Border Grid.Row="2" Margin="18" Padding="14" CornerRadius="10" Background="#1A2440">
          <StackPanel>
            <TextBlock Text="●  LOCAL ONLY" Foreground="#6CE9A6" FontSize="10" FontWeight="Bold" />
            <TextBlock x:Name="SidebarPrivacy" Foreground="#9AA4BE" FontSize="11" TextWrapping="Wrap" Margin="0,6,0,0" />
          </StackPanel>
        </Border>
      </Grid>
    </Border>

    <Grid Grid.Column="1">
      <Grid.RowDefinitions><RowDefinition Height="94" /><RowDefinition Height="*" /><RowDefinition Height="32" /></Grid.RowDefinitions>
      <Border Grid.Row="0" Background="White" BorderBrush="#E4E7EC" BorderThickness="0,0,0,1">
        <Grid Margin="28,0">
          <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
          <StackPanel VerticalAlignment="Center">
            <TextBlock x:Name="PageTitle" FontSize="24" FontWeight="Bold" Foreground="#182033" />
            <TextBlock x:Name="PageDescription" FontSize="13" Foreground="#667085" Margin="0,5,0,0" />
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
            <Button x:Name="AddButton" Style="{StaticResource SecondaryButton}" Margin="0,0,10,0" Click="AddButton_Click" />
            <Button x:Name="RefreshButton" Style="{StaticResource PrimaryButton}" Click="RefreshButton_Click" />
          </StackPanel>
        </Grid>
      </Border>

      <Grid Grid.Row="1">
        <ScrollViewer x:Name="DashboardPage" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <StackPanel Margin="28,26,28,40">
            <TextBlock x:Name="TodayOverviewLabel" Style="{StaticResource SectionLabel}" />
            <UniformGrid Columns="3" Margin="0,0,0,28">
              <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                <StackPanel><TextBlock x:Name="UsedTotalLabel" Foreground="#667085" /><TextBlock x:Name="UsedTotalValue" Text="0" FontSize="30" FontWeight="Bold" Foreground="#182033" Margin="0,10,0,0" /></StackPanel>
              </Border>
              <Border Style="{StaticResource Card}" Margin="5,0">
                <StackPanel><TextBlock x:Name="RemainingTotalLabel" Foreground="#667085" /><TextBlock x:Name="RemainingTotalValue" Text="0" FontSize="30" FontWeight="Bold" Foreground="#12B76A" Margin="0,10,0,0" /></StackPanel>
              </Border>
              <Border Style="{StaticResource Card}" Margin="10,0,0,0">
                <StackPanel><TextBlock x:Name="AccountCountLabel" Foreground="#667085" /><TextBlock x:Name="AccountCountValue" Text="0" FontSize="30" FontWeight="Bold" Foreground="#5B5FEF" Margin="0,10,0,0" /><TextBlock x:Name="ResetTimeLabel" Foreground="#98A2B3" FontSize="11" /></StackPanel>
              </Border>
            </UniformGrid>
            <TextBlock x:Name="AccountUsageLabel" Style="{StaticResource SectionLabel}" />
            <WrapPanel x:Name="DashboardCards" ItemWidth="390" />
          </StackPanel>
        </ScrollViewer>

        <ScrollViewer x:Name="AccountsPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="28,26,28,40">
            <StackPanel x:Name="AccountsList" />
          </StackPanel>
        </ScrollViewer>

        <ScrollViewer x:Name="TransferPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
          <Grid Margin="28,26,28,40">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="20" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource Card}" VerticalAlignment="Top">
              <StackPanel>
                <TextBlock x:Name="ExportTitle" FontSize="19" FontWeight="Bold" Foreground="#182033" />
                <TextBlock x:Name="ExportDescription" TextWrapping="Wrap" Foreground="#667085" Margin="0,8,0,18" />
                <CheckBox x:Name="SelectAllAccounts" Style="{StaticResource SettingsCheck}" Checked="SelectAllAccounts_Changed" Unchecked="SelectAllAccounts_Changed" />
                <Border BorderBrush="#E4E7EC" BorderThickness="0,1,0,1" Padding="0,10" Margin="0,8,0,16">
                  <StackPanel x:Name="ExportAccountList" />
                </Border>
                <TextBlock x:Name="BackupPasswordLabel" Foreground="#344054" Margin="0,0,0,6" />
                <PasswordBox x:Name="ExportPassword" Margin="0,0,0,12" />
                <TextBlock x:Name="ConfirmPasswordLabel" Foreground="#344054" Margin="0,0,0,6" />
                <PasswordBox x:Name="ExportPasswordConfirm" Margin="0,0,0,18" />
                <Button x:Name="ExportButton" Style="{StaticResource PrimaryButton}" Click="ExportButton_Click" />
              </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource Card}" VerticalAlignment="Top">
              <StackPanel>
                <TextBlock x:Name="ImportTitle" FontSize="19" FontWeight="Bold" Foreground="#182033" />
                <TextBlock x:Name="ImportDescription" TextWrapping="Wrap" Foreground="#667085" Margin="0,8,0,20" />
                <TextBlock x:Name="DuplicateModeLabel" Foreground="#344054" Margin="0,0,0,6" />
                <ComboBox x:Name="DuplicateModeCombo" Margin="0,0,0,20" />
                <Button x:Name="ImportButton" Style="{StaticResource PrimaryButton}" Click="ImportButton_Click" />
              </StackPanel>
            </Border>
          </Grid>
        </ScrollViewer>

        <ScrollViewer x:Name="SettingsPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="28,26,28,40" MaxWidth="820" HorizontalAlignment="Left">
            <TextBlock x:Name="SecuritySection" Style="{StaticResource SectionLabel}" />
            <Border Style="{StaticResource Card}" Margin="0,0,0,22">
              <StackPanel>
                <CheckBox x:Name="AppLockCheck" Style="{StaticResource SettingsCheck}" Click="AppLockCheck_Click" />
                <TextBlock x:Name="AppLockDescription" Foreground="#667085" TextWrapping="Wrap" Margin="24,0,0,12" />
                <Grid Margin="24,6,0,0">
                  <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="220" /></Grid.ColumnDefinitions>
                  <Button x:Name="SetPinButton" Grid.Column="0" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left" Click="SetPinButton_Click" />
                  <StackPanel Grid.Column="1">
                    <TextBlock x:Name="LockAfterLabel" Foreground="#344054" Margin="0,0,0,5" />
                    <ComboBox x:Name="LockAfterCombo" SelectionChanged="LockAfterCombo_SelectionChanged" />
                  </StackPanel>
                </Grid>
              </StackPanel>
            </Border>
            <TextBlock x:Name="BackgroundSection" Style="{StaticResource SectionLabel}" />
            <Border Style="{StaticResource Card}" Margin="0,0,0,22">
              <StackPanel>
                <CheckBox x:Name="BackgroundRefreshCheck" Style="{StaticResource SettingsCheck}" Click="BackgroundRefreshCheck_Click" />
                <TextBlock x:Name="BackgroundDescription" Foreground="#667085" TextWrapping="Wrap" Margin="24,0,0,14" />
                <Grid Margin="24,4,0,0">
                  <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="220" /></Grid.ColumnDefinitions>
                  <StackPanel>
                    <CheckBox x:Name="StartWindowsCheck" Style="{StaticResource SettingsCheck}" Click="StartWindowsCheck_Click" />
                    <CheckBox x:Name="MinimizeTrayCheck" Style="{StaticResource SettingsCheck}" Click="MinimizeTrayCheck_Click" />
                  </StackPanel>
                  <StackPanel Grid.Column="1">
                    <TextBlock x:Name="RefreshIntervalLabel" Foreground="#344054" Margin="0,0,0,5" />
                    <ComboBox x:Name="RefreshIntervalCombo" SelectionChanged="RefreshIntervalCombo_SelectionChanged" />
                  </StackPanel>
                </Grid>
              </StackPanel>
            </Border>
            <TextBlock x:Name="LanguageSection" Style="{StaticResource SectionLabel}" />
            <Border Style="{StaticResource Card}" Margin="0,0,0,22">
              <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="260" /></Grid.ColumnDefinitions>
                <StackPanel><TextBlock x:Name="AppLanguageLabel" FontSize="15" Foreground="#182033" /><TextBlock x:Name="LanguageDescription" Foreground="#667085" Margin="0,6,15,0" TextWrapping="Wrap" /></StackPanel>
                <ComboBox x:Name="LanguageCombo" Grid.Column="1" SelectionChanged="LanguageCombo_SelectionChanged" VerticalAlignment="Center" />
              </Grid>
            </Border>
            <TextBlock x:Name="PrivacySection" Style="{StaticResource SectionLabel}" />
            <Border Style="{StaticResource Card}"><TextBlock x:Name="PrivacyDescription" Foreground="#667085" TextWrapping="Wrap" LineHeight="22" /></Border>
          </StackPanel>
        </ScrollViewer>

        <ScrollViewer x:Name="HelpPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
          <Border Style="{StaticResource Card}" Margin="28,26,28,40" MaxWidth="760" HorizontalAlignment="Left" VerticalAlignment="Top">
            <StackPanel>
              <Border Background="#EEF0FF" CornerRadius="12" Padding="18" Margin="0,0,0,22">
                <TextBlock Text="Account Analytics · Read only" Foreground="#4549C9" FontWeight="Bold" FontSize="16" />
              </Border>
              <TextBlock x:Name="HelpSteps" Foreground="#344054" TextWrapping="Wrap" FontSize="15" LineHeight="24" />
            </StackPanel>
          </Border>
        </ScrollViewer>
      </Grid>

      <Border Grid.Row="2" Background="White" BorderBrush="#E4E7EC" BorderThickness="0,1,0,0">
        <TextBlock x:Name="StatusText" Foreground="#667085" FontSize="11" Margin="14,0" VerticalAlignment="Center" />
      </Border>
    </Grid>

    <Border x:Name="LockOverlay" Grid.ColumnSpan="2" Background="#E611182C" Visibility="Collapsed">
      <Border Width="420" Background="White" CornerRadius="18" Padding="34" HorizontalAlignment="Center" VerticalAlignment="Center">
        <StackPanel>
          <Border Width="60" Height="60" Background="#EEF0FF" CornerRadius="18" HorizontalAlignment="Center"><TextBlock Text="🔒" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
          <TextBlock x:Name="UnlockTitle" FontSize="23" FontWeight="Bold" Foreground="#182033" HorizontalAlignment="Center" Margin="0,18,0,0" />
          <TextBlock x:Name="UnlockDescription" Foreground="#667085" TextWrapping="Wrap" TextAlignment="Center" Margin="0,8,0,18" />
          <PasswordBox x:Name="UnlockPin" FontSize="18" MaxLength="32" Margin="0,0,0,12" KeyDown="UnlockPin_KeyDown" />
          <TextBlock x:Name="UnlockError" Foreground="#D92D20" HorizontalAlignment="Center" Margin="0,0,0,10" />
          <Button x:Name="UnlockButton" Style="{StaticResource PrimaryButton}" Click="UnlockButton_Click" />
        </StackPanel>
      </Border>
    </Border>
  </Grid>
</Window>
