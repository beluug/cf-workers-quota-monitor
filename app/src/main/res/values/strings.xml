    <string name="help_title">Beginner setup guide</string>
    <string name="help_intro_title">Ready in about 3 minutes</string>
    <string name="help_intro_body">Create one least-privilege token for each Cloudflare account. It is safe and easy to revoke.</string>
    <string name="help_step1_title">Sign in to Cloudflare</string>
    <string name="help_step1_body">Open dash.cloudflare.com in a browser, sign in, and choose the account you want to monitor.</string>
    <string name="help_step2_title">Copy the Account ID</string>
    <string name="help_step2_body">Open Workers &amp; Pages. Find the 32-character Account ID on the page or account overview and copy it into this app.</string>
    <string name="help_step3_title">Create a read-only API Token</string>
    <string name="help_step3_body">Open Profile → API Tokens → Create Custom Token. Add only Account → Account Analytics → Read, and limit resources to the account being monitored.</string>
    <string name="help_step4_title">Copy and save the token</string>
    <string name="help_step4_body">Cloudflare shows the full token only once. Copy it into this app. Never use a Global API Key or commit a token to GitHub.</string>
    <string name="help_step5_title">View the result</string>
    <string name="help_step5_body">The app queries Workers requests from UTC 00:00 to now. The default Free limit is 100,000 requests per day.</string>
    <string name="help_why_title">Why is the remaining quota an estimate?</string>
    <string name="help_why_body">Cloudflare Analytics can lag by several minutes and is not the billing counter. Leave a safety margin near 100%. Background refresh can be enabled or disabled in Settings.</string>
